# ActivityMaster Core example environment variables (per rules/generative/platform/secrets-config/env-variables.md)
PORT=8080
ENVIRONMENT=dev
SERVICE_NAME=activitymaster-core

# Database
DB_URL=postgresql://localhost:5432/activitymaster
DB_USER=activitymaster
DB_PASS=activitymaster
DB_POOL_SIZE=10
TEST_DB_CONTAINER_IMAGE=postgres:15

# Security
OAUTH2_ISSUER_URL=https://auth.example.com
OAUTH2_REALM=activitymaster
OAUTH2_CLIENT_ID=activitymaster-client
JWKS_URI=https://auth.example.com/realms/activitymaster/protocol/openid-connect/certs
JWT_TEST_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9

# Observability
TRACING_ENABLED=true
LOGGING_BACKEND=log4j2
METRICS_EXPORT=enabled
CLOUDEVENTS_FORMAT=application/cloudevents+json
ENABLE_DEBUG_LOGS=false
