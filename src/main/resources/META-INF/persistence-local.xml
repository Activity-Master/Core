<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" version="2.1" xmlns="http://xmlns.jcp.org/xml/ns/persistence" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/persistence http://xmlns.jcp.org/xml/ns/persistence/persistence_2_1.xsd">
    <persistence-unit name="ActivityMaster" transaction-type="JTA">

        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <jta-data-source>jdbc/activitymaster</jta-data-source>

        <class>com.entityassist.converters.LocalDateAttributeConverter</class>
        <class>com.entityassist.converters.LocalDateTimeAttributeConverter</class>
        <class>com.entityassist.converters.LocalDateTimestampAttributeConverter</class>

        <exclude-unlisted-classes>false</exclude-unlisted-classes>

        <shared-cache-mode>ENABLE_SELECTIVE</shared-cache-mode>
        <validation-mode>NONE</validation-mode>
        <properties>
            <property name="hibernate.show_sql" value="false"/>
            <property name="hibernate.format_sql" value="false"/>
            <property name="hibernate.connection.useUnicode" value="yes"/>
            <property name="hibernate.connection.characterEncoding" value="UTF-8"/>
            <property name="javax.persistence.jdbc.url" value="jdbc:sqlserver://localhost;DatabaseName=FSDM"/>
            <property name="javax.persistence.jdbc.user" value=""/>
            <property name="javax.persistence.jdbc.password" value=""/>
            <property name="javax.persistence.jdbc.driver" value="com.microsoft.sqlserver.jdbc.SQLServerDriver"/>
            <property name="hibernate.enable_lazy_load_no_trans" value="true"/>
            <property name="hibernate.max_fetch_depth" value="1"/>
            <property name="hibernate.hbm2ddl.auto" value="none"/>
        </properties>
    </persistence-unit>

    <persistence-unit name="ActivityMasterUT" transaction-type="JTA">

        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <jta-data-source>jdbc/activitymaster</jta-data-source>

        <class>com.entityassist.converters.LocalDateAttributeConverter</class>
        <class>com.entityassist.converters.LocalDateTimeAttributeConverter</class>
        <class>com.entityassist.converters.LocalDateTimestampAttributeConverter</class>

        <exclude-unlisted-classes>false</exclude-unlisted-classes>
        <shared-cache-mode>ENABLE_SELECTIVE</shared-cache-mode>
        <validation-mode>NONE</validation-mode>

        <properties>
            <property name="hibernate.show_sql" value="false"/>
            <property name="hibernate.format_sql" value="false"/>
            <property name="hibernate.connection.useUnicode" value="yes"/>
            <property name="hibernate.connection.characterEncoding" value="UTF-8"/>
            <property name="javax.persistence.jdbc.url" value="jdbc:sqlserver://localhost;DatabaseName=FSDM"/>
            <property name="javax.persistence.jdbc.user" value=""/>
            <property name="javax.persistence.jdbc.password" value=""/>
            <property name="javax.persistence.jdbc.driver" value="com.microsoft.sqlserver.jdbc.SQLServerDriver"/>

            <property name="hibernate.enable_lazy_load_no_trans" value="true"/>
            <property name="hibernate.max_fetch_depth" value="1"/>
            <property name="hibernate.hbm2ddl.auto" value="none"/>
        </properties>
    </persistence-unit>

</persistence>

