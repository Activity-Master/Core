<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" version="2.1" xmlns="http://xmlns.jcp.org/xml/ns/persistence" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/persistence http://xmlns.jcp.org/xml/ns/persistence/persistence_2_1.xsd">
    <persistence-unit name="ActivityMaster" transaction-type="JTA">

        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <jta-data-source>jdbc/activitymaster</jta-data-source>

        <class>com.jwebmp.entityassist.converters.LocalDateAttributeConverter</class>
        <class>com.jwebmp.entityassist.converters.LocalDateTimeAttributeConverter</class>
        <class>com.jwebmp.entityassist.converters.LocalDateTimestampAttributeConverter</class>

        <exclude-unlisted-classes>false</exclude-unlisted-classes>

        <shared-cache-mode>ENABLE_SELECTIVE</shared-cache-mode>
        <validation-mode>NONE</validation-mode>
        <properties>
            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>
            <property name="hibernate.connection.useUnicode" value="yes"/>
            <property name="hibernate.connection.characterEncoding" value="UTF-8"/>
            <property name="javax.persistence.jdbc.url" value="jdbc:sqlserver://localhost;DatabaseName=ActivityMasterAuto"/>
            <property name="javax.persistence.jdbc.driver" value="com.microsoft.sqlserver.jdbc.SQLServerDriver"/>
            <!--
                        <property name="hibernate.hbm2ddl.auto" value="update"/>
            -->

            <!--

                        <property name="hibernate.transaction.manager_lookup_class" value="org.hibernate.transaction.BTMTransactionManagerLookup"/>
                        <property name="hibernate.jndi.class" value="bitronix.tm.jndi.BitronixInitialContextFactory"/>
            -->

            <!--
                        <property name="javax.persistence.schema-generation.scripts.create-target" value="./META-INF/CreateDB.sql"/>
                        <property name="javax.persistence.schema-generation.scripts.drop-target" value="./META-INF/DropTables.sql"/>-->


            <property name="hibernate.enable_lazy_load_no_trans" value="true"/>
            <property name="hibernate.max_fetch_depth" value="1"/>

        </properties>
    </persistence-unit>
    <persistence-unit name="ActivityMasterUT" transaction-type="JTA">

        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <jta-data-source>jdbc/activitymaster</jta-data-source>

        <class>com.jwebmp.entityassist.converters.LocalDateAttributeConverter</class>
        <class>com.jwebmp.entityassist.converters.LocalDateTimeAttributeConverter</class>
        <class>com.jwebmp.entityassist.converters.LocalDateTimestampAttributeConverter</class>

        <exclude-unlisted-classes>false</exclude-unlisted-classes>
        <shared-cache-mode>ALL</shared-cache-mode>
        <validation-mode>NONE</validation-mode>

        <properties>
            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="false"/>
            <property name="hibernate.connection.useUnicode" value="yes"/>
            <property name="hibernate.connection.characterEncoding" value="UTF-8"/>
            <property name="javax.persistence.jdbc.driver" value="com.microsoft.sqlserver.jdbc.SQLServerDriver"/>

            <property name="hibernate.enable_lazy_load_no_trans" value="true"/>
            <property name="hibernate.max_fetch_depth" value="1"/>
            <property name="hibernate.hbm2ddl.auto" value="none"/>


            <!--          <property name="javax.persistence.schema-generation.scripts.action" value="drop-and-create"/>
                      <property name="javax.persistence.schema-generation.scripts.create-target" value="./CreateDB.sql"/>
                      <property name="javax.persistence.schema-generation.scripts.drop-target" value="./DropTables.sql"/>

                      <property name="hibernate.hbm2ddl.auto" value="update"/>-->

        </properties>
    </persistence-unit>

</persistence>

